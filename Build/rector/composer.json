{
  "name": "erhaweb/feed-display-rector-tools",
  "description": "Dedicated Rector tooling for feed_display",
  "license": "GPL-2.0-or-later",
  "type": "project",
  "require": {
    "php": "^8.1"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.0",
    "ssch/typo3-rector": "^2.15 || ^3.11",
    "typo3/coding-standards": "^0.8"
  },
  "config": {
    "vendor-dir": "../../.Build/rector/vendor",
    "bin-dir": "../../.Build/rector/bin",
    "lock": false,
    "preferred-install": {
      "*": "dist"
    },
    "sort-packages": true
  },
  "scripts": {
    "check": [
      "../../.Build/rector/bin/rector process --config=rector.php --ansi --dry-run",
      "../../.Build/rector/bin/php-cs-fixer fix --config=../php-cs-fixer/config.php -v --dry-run --diff"
    ],
    "fix": [
      "../../.Build/rector/bin/rector process --config=rector.php --ansi",
      "../../.Build/rector/bin/php-cs-fixer fix --config=../php-cs-fixer/config.php -v"
    ]
  }
}
